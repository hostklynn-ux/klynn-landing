# ==============================================
# LANDING SERVICE - ENVIRONMENT VARIABLES EXAMPLE
# ==============================================
# Copy this file to .env.development and fill in your values

# Public Environment Variables (exposed to browser)
NEXT_PUBLIC_API_URL=https://api.getklynn.com/api/v1
NEXT_PUBLIC_APP_NAME=Klynn
NEXT_PUBLIC_APP_VERSION=1.0.0

# Server-side Only Variables
NODE_ENV=production
PORT=3000

# API Configuration
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3
